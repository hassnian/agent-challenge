{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "dashboard",
    "system_requirements": {
      "required_vram": 21
    }
  },
  "global": {
    "variables": {
      "MODEL": "gemma4:26b"
    }
  },
  "ops": [
    {
      "id": "ollama-server",
      "type": "container/run",
      "args": {
        "gpu": true,
        "image": "docker.io/ollama/ollama:0.20.0",
        "expose": [
          {
            "port": 11434,
            "health_checks": [
              {
                "type": "http",
                "path": "/api/tags",
                "method": "GET",
                "expected_status": 200,
                "continuous": false
              }
            ]
          }
        ],
        "resources": [
          {
            "type": "Ollama",
            "model": "%%global.variables.MODEL%%"
          }
        ]
      },
      "execution": {
        "group": "app"
      }
    },
    {
      "id": "eliza-api",
      "type": "container/run",
      "args": {
        "image": "hassnian/nosana-eliza-agent:nosana-amd64-v2",
        "cmd": [
          "npm",
          "start"
        ],
        "env": {
          "OPENAI_API_KEY": "ollama",
          "OPENAI_BASE_URL": "http://ollama-server:11434/v1",
          "OPENAI_SMALL_MODEL": "%%global.variables.MODEL%%",
          "OPENAI_LARGE_MODEL": "%%global.variables.MODEL%%",
          "OPENAI_EMBEDDING_URL": "https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1",
          "OPENAI_EMBEDDING_API_KEY": "nosana",
          "OPENAI_EMBEDDING_MODEL": "Qwen3-Embedding-0.6B",
          "OPENAI_EMBEDDING_DIMENSIONS": "1024",
          "SERPER_API_KEY": "REPLACE_WITH_YOUR_SERPER_KEY",
          "SECRET_SALT": "REPLACE_WITH_A_RANDOM_SECRET",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production"
        },
        "expose": [
          {
            "port": 3000,
            "health_checks": [
              {
                "type": "http",
                "path": "/api/server/ping",
                "method": "GET",
                "expected_status": 200,
                "continuous": true
              }
            ]
          }
        ]
      },
      "execution": {
        "group": "app",
        "depends_on": [
          "ollama-server"
        ]
      }
    }
  ]
}
