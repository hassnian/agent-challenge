{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "api",
    "system_resources": {
      "required_vram": 16
    }
  },
  "ops": [
    {
      "id": "agent",
      "type": "container/run",
      "args": {
        "image": "hassnian/nosana-eliza-agent:latest",
        "cmd": ["/bin/sh", "-c", "/app/scripts/start-nosana-container.sh"],
        "gpu": true,
        "expose": 3000,
        "env": {
          "ENABLE_OLLAMA": "true",
          "OLLAMA_MODEL": "qwen2.5:7b-instruct",
          "OPENAI_API_KEY": "ollama",
          "OPENAI_BASE_URL": "http://127.0.0.1:11434/v1",
          "OPENAI_SMALL_MODEL": "qwen2.5:7b-instruct",
          "OPENAI_LARGE_MODEL": "qwen2.5:7b-instruct",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production"
        }
      },
      "execution": {
        "group": "run"
      }
    }
  ]
}
