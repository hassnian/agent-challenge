{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "api",
    "system_resources": {
      "required_vram": 12
    }
  },
  "ops": [
    {
      "id": "vllm-server",
      "type": "container/run",
      "args": {
        "image": "docker.io/vllm/vllm-openai:v0.5.4",
        "cmd": [
          "--model",
          "/models",
          "--served-model-name",
          "Qwen-7B",
          "--host",
          "0.0.0.0",
          "--port",
          "9000"
        ],
        "gpu": true,
        "resources": [
          {
            "type": "HF",
            "repo": "Qwen/Qwen-7B",
            "target": "/models"
          }
        ],
        "expose": [
          {
            "port": 9000,
            "health_checks": [
              {
                "type": "http",
                "path": "/v1/models",
                "method": "GET",
                "expected_status": 200,
                "continuous": true
              }
            ]
          }
        ]
      },
      "execution": {
        "group": "inference"
      }
    },
    {
      "id": "eliza-api",
      "type": "container/run",
      "args": {
        "image": "hassnian/nosana-eliza-agent:latest",
        "cmd": [
          "/bin/sh",
          "-c",
          "elizaos start"
        ],
        "env": {
          "OPENAI_API_KEY": "local",
          "OPENAI_BASE_URL": "http://vllm-server:9000/v1",
          "OPENAI_SMALL_MODEL": "Qwen-7B",
          "OPENAI_LARGE_MODEL": "Qwen-7B",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production"
        },
        "expose": 3000
      },
      "execution": {
        "group": "app",
        "depends_on": [
          "vllm-server"
        ]
      }
    }
  ]
}
