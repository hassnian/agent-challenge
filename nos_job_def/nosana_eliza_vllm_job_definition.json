{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "dashboard",
    "system_requirements": {
      "required_vram": 12
    }
  },
  "ops": [
    {
      "id": "vllm-server",
      "type": "container/run",
      "args": {
        "image": "docker.io/vllm/vllm-openai:v0.5.4",
        "cmd": [
          "--model",
          "/models",
          "--served-model-name",
          "Qwen3.5-9B",
          "--host",
          "0.0.0.0",
          "--port",
          "9000"
        ],
        "gpu": true,
        "resources": [
          {
            "type": "HF",
            "repo": "Qwen/Qwen3.5-9B",
            "target": "/models"
          }
        ],
        "expose": [
          {
            "port": 9000,
            "health_checks": [
              {
                "type": "http",
                "path": "/v1/models",
                "method": "GET",
                "expected_status": 200,
                "continuous": true
              }
            ]
          }
        ]
      },
      "execution": {
        "group": "app"
      }
    },
    {
      "id": "eliza-api",
      "type": "container/run",
      "args": {
        "image": "hassnian/nosana-eliza-agent:nosana-amd64-v2",
        "cmd": [
          "npm",
          "start"
        ],
        "env": {
          "OPENAI_API_KEY": "local",
          "OPENAI_BASE_URL": "http://vllm-server:9000/v1",
          "OPENAI_SMALL_MODEL": "Qwen3.5-9B",
          "OPENAI_LARGE_MODEL": "Qwen3.5-9B",
          "SERPER_API_KEY": "REPLACE_WITH_YOUR_SERPER_KEY",
          "SECRET_SALT": "REPLACE_WITH_A_RANDOM_SECRET",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production"
        },
        "expose": [
          {
            "port": 3000,
            "health_checks": [
              {
                "type": "http",
                "path": "/api/server/ping",
                "method": "GET",
                "expected_status": 200,
                "continuous": true
              }
            ]
          }
        ]
      },
      "execution": {
        "group": "app",
        "depends_on": [
          "vllm-server"
        ]
      }
    }
  ]
}
